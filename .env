# ─── Variables de Entorno para Patitas Felices ───
# En Render, estas variables se configuran en la pestaña "Environment"

# 1. Conexión a la base de datos PostgreSQL (Supabase)
DATABASE_URL=tu_cadena_de_conexion_de_supabase_aqui

# 2. Puerto local (Render asignará el suyo automáticamente)
PORT=3000

# 3. Clave secreta para JWT
JWT_SECRET=patitas_felices_clave_super_secreta_2026

# 4. Configuración de CORS
CORS_ORIGIN=*

# 5. Configuración de Nodemailer para correos automáticos
EMAIL_USER=tu_correo_del_proyecto@gmail.com
EMAIL_PASS=tu_contrasena_de_aplicacion
